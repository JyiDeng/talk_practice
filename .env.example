# Frontend
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-publishable-key
VITE_SUPABASE_PRACTICE_AUDIO_BUCKET=practice-audio
VITE_SUPABASE_SCENARIO_AUDIO_BUCKET=scenario-audio
VITE_SUPABASE_AVATARS_BUCKET=avatars

# Supabase Edge Functions
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-secret-key

# LLM provider selection: qwen | openai-compatible
LLM_PROVIDER=qwen

# Aliyun DashScope / Qwen
QWEN_API_KEY=your-qwen-api-key
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_ASR_MODEL=paraformer-v2

# Optional OpenAI-compatible fallback
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_MODEL=
